<robot name="KISTAR_SON_RIGHT">

  <mujoco>
    <compiler meshdir="01_kistar_son_STL/" balanceinertia="true" discardvisual="false" strippath="true" boundmass="0.0001" boundinertia="0.000000001"/>
    <option>
      <flag contact="disable"/>
    </option>
    <default>
      <position kp="2" kv="0.1" forcerange="-0.2 0.2"/>
    </default>
    <actuator>
      <!-- THUMB (thumb_5 is mimic of thumb_4 - not actuated) -->
      <position name="right_hand_thumb_0_act" joint="right_hand_thumb_0_joint" ctrlrange="-0.7854 0.7854"/>
      <position name="right_hand_thumb_1_act" joint="right_hand_thumb_1_joint" ctrlrange="-0.7854 0.7854"/>
      <position name="right_hand_thumb_2_act" joint="right_hand_thumb_2_joint" ctrlrange="-1.0472 1.0472"/>
      <position name="right_hand_thumb_3_act" joint="right_hand_thumb_3_joint" ctrlrange="0 1.5708"/>
      <!-- INDEX (index_3 is mimic of index_2) -->
      <position name="right_hand_index_0_act" joint="right_hand_index_0_joint" ctrlrange="-0.261799 0.261799"/>
      <position name="right_hand_index_1_act" joint="right_hand_index_1_joint" ctrlrange="0 1.5708"/>
      <position name="right_hand_index_2_act" joint="right_hand_index_2_joint" ctrlrange="0 1.5708"/>
      <!-- MIDDLE (middle_3 is mimic of middle_2) -->
      <position name="right_hand_middle_0_act" joint="right_hand_middle_0_joint" ctrlrange="-0.261799 0.261799"/>
      <position name="right_hand_middle_1_act" joint="right_hand_middle_1_joint" ctrlrange="0 1.5708"/>
      <position name="right_hand_middle_2_act" joint="right_hand_middle_2_joint" ctrlrange="0 1.5708"/>
      <!-- RING (ring_3 is mimic of ring_2) -->
      <position name="right_hand_ring_0_act" joint="right_hand_ring_0_joint" ctrlrange="-0.261799 0.261799"/>
      <position name="right_hand_ring_1_act" joint="right_hand_ring_1_joint" ctrlrange="0 1.5708"/>
      <position name="right_hand_ring_2_act" joint="right_hand_ring_2_joint" ctrlrange="0 1.5708"/>
      <!-- LITTLE (little_2 is mimic of little_1) -->
      <position name="right_hand_little_0_act" joint="right_hand_little_0_joint" ctrlrange="-0.261799 0.261799"/>
      <position name="right_hand_little_1_act" joint="right_hand_little_1_joint" ctrlrange="0 1.5708"/>
    </actuator>
  </mujoco>

